# ============================================
# ServiceWala Backend - Environment Variables
# ============================================

# Server Configuration
# --------------------
NODE_ENV=development
PORT=5000

# Database Configuration
# ----------------------
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string_here

# JWT Configuration
# -----------------
# Secret key for JWT token generation (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Razorpay Configuration
# ----------------------
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# Email Configuration
# -------------------
# Option A (recommended on Render): Resend API – no SMTP blocking
# Get API key: https://resend.com → Sign up → API Keys
RESEND_API_KEY=
# Sender (use onboarding@resend.dev for testing; verify your domain for production)
RESEND_FROM=ServiceWala <onboarding@resend.dev>

# Option B: SMTP (works locally; often blocked on Render free tier)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_here
EMAIL_PASS=your_email_app_password_here
EMAIL_FROM=ServiceWala <no-reply@servicewala.com>

# CORS / Frontend URLs
# --------------------
# Comma-separated list of allowed origins (e.g. http://localhost:3000,https://yoursite.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL for password reset emails
FRONTEND_URL=http://localhost:3000

# Cloudinary Configuration
# -------------------------
# Get these from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ============================================
# Setup Instructions:
# ============================================
# 1. Copy this file as .env in the root directory
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit the .env file to version control
# 4. Add .env to .gitignore
# ============================================
